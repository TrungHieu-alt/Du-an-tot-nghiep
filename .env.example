# Matching V2 Prototype - PostgreSQL + pgvector
# Docker Compose defaults to POSTGRES_HOST=postgres. From a host-local backend,
# use POSTGRES_HOST=localhost and POSTGRES_PORT=5433.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=jobmatcher
POSTGRES_PASSWORD=jobmatcher
POSTGRES_DB=jobmatcher_v2

# Backend authentication
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
GOOGLE_CLIENT_ID=

# Frontend runtime
VITE_API_BASE_URL=http://localhost:8000
VITE_GOOGLE_CLIENT_ID=
