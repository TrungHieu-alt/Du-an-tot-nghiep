# Backend runtime
MONGO_URI=mongodb://jobmatcher-mongo:27017/jobmatcher
DB_NAME=job_matching
GEMINI_API_KEY=

# Matching V2 Prototype - PostgreSQL + pgvector
# Inside docker compose use POSTGRES_HOST=postgres; from host use localhost.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=jobmatcher
POSTGRES_PASSWORD=jobmatcher
POSTGRES_DB=jobmatcher_v2

# Frontend runtime
VITE_API_BASE_URL=http://localhost:8000
DEV_ALLOW_ALL_ACCOUNTS=true 
AI_MODE=live # mock/live
GEMINI_MODEL=gemini-3.1-flash-lite-preview # or gemini-2.5-flash-lite