# Backend runtime
# Optional override. By default docker-compose uses mongodb://mongo:27017
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
DB_NAME=job_matching
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
MASTODON_API_BASE_URL=
MASTODON_ACCESS_TOKEN=
MONGO_URI=mongodb://jobmatcher-mongo:27017/jobmatcher
# Frontend runtime
VITE_API_BASE_URL=http://localhost:8000
